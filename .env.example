ANTHROPIC_API_KEY=

# Optional: switch the agent to OpenAI, Azure OpenAI, or any OpenAI-compatible
# endpoint instead of Anthropic. See src/agent/providers/openai_provider.py.
# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_API_VERSION=
# OPENAI_MODEL=gpt-4o

# Optional: point the agent at Postgres instead of the bundled SQLite demo db.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
